<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Court" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Color principal -->
        <item name="colorPrimary">@color/principal</item>
        <item name="colorPrimaryVariant">@color/texto_principal_oscuro</item>
        <item name="colorOnPrimary">@color/texto_claro</item>

        <!-- Acento -->
        <item name="colorSecondary">@color/acento</item>
        <item name="colorSecondaryVariant">@color/acento</item>
        <item name="colorOnSecondary">@color/texto_claro</item>

        <!-- Fondo oscuro -->
        <item name="android:colorBackground">@color/fondo_oscuro</item>
        <item name="colorSurface">@color/fondo_tarjeta_oscuro</item>
        <item name="colorOnSurface">@color/texto_principal_oscuro</item>

        <!-- Texto -->
        <item name="android:textColorPrimary">@color/texto_principal_oscuro</item>
        <item name="android:textColorSecondary">@color/texto_secundario_oscuro</item>

        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.Court.NoActionBar" parent="Theme.Court">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
</resources>
