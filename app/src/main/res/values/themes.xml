<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Court" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Color principal de la app -->
        <item name="colorPrimary">@color/principal</item>
        <item name="colorPrimaryVariant">@color/texto_principal</item>
        <item name="colorOnPrimary">@color/texto_claro</item>

        <!-- Color de acento (botones, FAB, switches) -->
        <item name="colorSecondary">@color/acento</item>
        <item name="colorSecondaryVariant">@color/acento</item>
        <item name="colorOnSecondary">@color/texto_claro</item>

        <!-- Fondo y superficie -->
        <item name="android:colorBackground">@color/fondo</item>
        <item name="colorSurface">@color/fondo_tarjeta</item>
        <item name="colorOnSurface">@color/texto_principal</item>

        <!-- Texto -->
        <item name="android:textColorPrimary">@color/texto_principal</item>
        <item name="android:textColorSecondary">@color/texto_secundario</item>

        <!-- Sin ActionBar por defecto — usamos Toolbar personalizada -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Tema para el Splash / Onboarding (sin barra superior) -->
    <style name="Theme.Court.NoActionBar" parent="Theme.Court">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
</resources>